@using Razor_Views.Models;
@{
	string appTitle = "I'm  currently watching better call saul";
	Person person = new Person()
			{
				Name = "Rahul", DateOfBirth = Convert.ToDateTime("1998-01-02")
			};
}
<!DOCTYPE html>

<html>
	<head>
		<title>
			Hello Mvc View
		</title>
		<meta charset="utf-8" />
	</head>
	<body>
		<div>
			<h1>@appTitle</h1>
			<h2>@person.Name</h2>
			@{
				double age = Math.Round((DateTime.Now - person.DateOfBirth).TotalDays / 365.25); 	
			}
			<h3>
				@age
			</h3>
		</div>
	</body>
</html>